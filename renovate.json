{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "customDatasources": {
    "conan-files": {
      "defaultRegistryUrlTemplate": "https://raw.githubusercontent.com/opendocument-app/conan-odr-index/refs/heads/main/recipes/{{ packageName }}/config.yml",
      "format": "yaml",
      "transformTemplates": [
        "{ \"releases\": versions.$keys().{ \"version\": $ } }"
      ]
    }
  },
  
  "packageRules": [
    {
      "matchDatasources": ["conan"],
      "matchPackageNames": ["pdf2htmlex/**"],
      "overrideDatasource": "conan-files"
    }
  ]
}
