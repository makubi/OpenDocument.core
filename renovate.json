{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "customDatasources": {
    "conan-files": {
      "defaultRegistryUrlTemplate": "https://raw.githubusercontent.com/makubi/OpenDocument.core/refs/heads/main/renovate-version.json"
    }
  },
  
  "packageRules": [
    {
      "matchDatasources": ["conan"],
      "matchPackageNames": ["pdf2htmlex/**", "odrcore/**"],
      "registryUrls": ["https://raw.githubusercontent.com/opendocument-app/conan-odr-index/refs/heads/main/recipes/odrcore/config.yml"]
    }
  ]
}
